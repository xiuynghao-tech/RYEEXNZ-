-- ════════════════════════════════════════
--        FREECAM FUNCTIONS
-- ════════════════════════════════════════
local function EnableFreeCam()
    if FreeCamState.Enabled then return end
    FreeCamState.Enabled    = true
    FreeCamState._savedCType = Camera.CameraType
    FreeCamState._savedFOV   = Camera.FieldOfView

    Camera.CameraType = Enum.CameraType.Scriptable

    FreeCamState._targetCFrame = Camera.CFrame
    FreeCamState._currentCF    = Camera.CFrame
    FreeCamState._targetFOV    = FreeCamState.FOV
    FreeCamState._currentFOV   = Camera.FieldOfView

    local look = Camera.CFrame.LookVector
    FreeCamState._pitch = math.asin(-look.Y)
    FreeCamState._yaw   = math.atan2(-look.X, -look.Z)

    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

    FreeCamState._connection = RunService.RenderStepped:Connect(function(dt)
        local smooth = math.clamp(FreeCamState.SmoothFactor, 0.01, 1)

        -- Mouse look
        local delta = UserInputService:GetMouseDelta()
        FreeCamState._pitch = math.clamp(FreeCamState._pitch - delta.Y * 0.003, -math.pi/2 + 0.01, math.pi/2 - 0.01)
        FreeCamState._yaw   = FreeCamState._yaw - delta.X * 0.003

        local rotation = CFrame.Angles(0, FreeCamState._yaw, 0) * CFrame.Angles(FreeCamState._pitch, 0, 0)

        -- Speed modifier
        local spd = FreeCamState.Speed
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            spd = spd * 3
        elseif UserInputService:IsKeyDown(Enum.KeyCode.C) then
            spd = spd * 0.2
        end

        -- Movement
        local moveDir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + rotation.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - rotation.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - rotation.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + rotation.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then moveDir = moveDir + Vector3.new(0,1,0)   end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then moveDir = moveDir - Vector3.new(0,1,0)   end
        if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end

        local newPos = FreeCamState._targetCFrame.Position + moveDir * spd * dt
        FreeCamState._targetCFrame = CFrame.new(newPos) * rotation

        FreeCamState._currentCF  = FreeCamState._currentCF:Lerp(FreeCamState._targetCFrame, smooth)
        FreeCamState._currentFOV = FreeCamState._currentFOV + (FreeCamState._targetFOV - FreeCamState._currentFOV) * smooth

        Camera.CFrame      = FreeCamState._currentCF
        Camera.FieldOfView = FreeCamState._currentFOV
    end)
end

local function DisableFreeCam()
    if not FreeCamState.Enabled then return end
    FreeCamState.Enabled = false
    if FreeCamState._connection then
        FreeCamState._connection:Disconnect()
        FreeCamState._connection = nil
    end
    Camera.CameraType  = FreeCamState._savedCType or Enum.CameraType.Custom
    Camera.FieldOfView = FreeCamState._savedFOV   or 70
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
end

