-- Fungsi untuk toggle freecam
local function toggleFreecam()
    State.Enabled = not State.Enabled
    
    if State.Enabled then
        -- Simpan posisi kamera awal
        State.CameraPosition = Camera.CFrame.Position
        State.TargetPosition = State.CameraPosition
        
        -- Simpan rotasi awal
        local _, lookY = Camera.CFrame:ToOrientation()
        State.CameraRotation = Vector2.new(math.deg(lookY), 0)
        State.TargetRotation = State.CameraRotation
        
        -- Set camera type
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.FieldOfView = State.FOV
        
        -- Lock mouse
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        UserInputService.MouseIconEnabled = false
        
        WindUI:Notify({
            Title = "✅ Freecam Enabled",
            Content = "Gunakan WASD untuk bergerak, Q/E naik turun",
            Duration = 3
        })
    else
        -- Kembalikan camera ke player
        Camera.CameraType = Enum.CameraType.Custom
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
        
        -- Hapus grid
        if State.ShowGrid then
            for _, part in ipairs(State.GridParts) do
                if part then part:Destroy() end
            end
            State.GridParts = {}
        end
        
        WindUI:Notify({
            Title = "⏹ Freecam Disabled",
            Content = "Kamera kembali ke player",
            Duration = 2
        })
    end
end

-- Fungsi untuk reset kamera ke posisi awal player
local function resetCamera()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local rootPart = LocalPlayer.Character.HumanoidRootPart
        State.TargetPosition = rootPart.Position + Vector3.new(0, 2, 5)
        State.TargetRotation = Vector2.new(0, 0)
        
        WindUI:Notify({
            Title = "🔄 Camera Reset",
            Content = "Kamera kembali ke posisi player",
            Duration = 2
        })
    end
end

-- Fungsi untuk membuat grid visual
local function createGrid()
    -- Hapus grid lama
    for _, part in ipairs(State.GridParts) do
        if part then part:Destroy() end
    end
    State.GridParts = {}
    
    if not State.ShowGrid then return end
    
    local gridSize = 50
    local spacing = 5
    local center = State.CameraPosition
    
    -- Buat grid lines
    for x = -gridSize, gridSize, spacing do
        for z = -gridSize, gridSize, spacing do
            -- Buat titik grid
            local part = Instance.new("Part")
            part.Size = Vector3.new(0.2, 0.2, 0.2)
            part.Position = center + Vector3.new(x, 0, z)
            part.Anchored = true
            part.CanCollide = false
            part.Transparency = 0.5
            part.BrickColor = BrickColor.new("Medium stone grey")
            part.Material = Enum.Material.Neon
            part.Parent = Workspace
            
            table.insert(State.GridParts, part)
        end
    end
end

-- Fungsi untuk mulai merekam path
local function startRecording()
    State.IsRecording = true
    State.RecordedPath = {}
    
    WindUI:Notify({
        Title = "⏺ Recording Started",
        Content = "Merekam path kamera...",
        Duration = 2
    })
end

-- Fungsi untuk stop merekam
local function stopRecording()
    State.IsRecording = false
    
    if #State.RecordedPath > 0 then
        local pathName = "Path_" .. os.date("%Y%m%d_%H%M%S")
        State.SavedPaths[pathName] = State.RecordedPath
        
        WindUI:Notify({
            Title = "✅ Recording Saved",
            Content = string.format("Path tersimpan: %s (%d titik)", pathName, #State.RecordedPath),
            Duration = 3
        })
        
        -- Update dropdown
        if _G.PathDropdown and _G.PathDropdown.UpdateValues then
            local pathNames = {}
            for name, _ in pairs(State.SavedPaths) do
                table.insert(pathNames, name)
            end
            _G.PathDropdown:UpdateValues(pathNames)
        end
    end
end

-- Fungsi untuk memutar path
local function playPath(pathName)
    if not State.SavedPaths[pathName] then return end
    
    State.IsPlayingPath = true
    State.CurrentPathIndex = 1
    State.RecordedPath = State.SavedPaths[pathName]
    
    WindUI:Notify({
        Title = "▶ Playing Path",
        Content = "Memutar: " .. pathName,
        Duration = 2
    })
end

-- Fungsi untuk stop memutar path
local function stopPath()
    State.IsPlayingPath = false
    State.CurrentPathIndex = 1
    
    WindUI:Notify({
        Title = "⏹ Path Stopped",
        Content = "Playback path dihentikan",
        Duration = 2
    })
end

