-- Scan semua remote
local function ScanAllRemotes()
    ScannedRemotes = {}
    
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            table.insert(ScannedRemotes, {
                Type = "RemoteEvent",
                Name = obj.Name,
                Class = obj.ClassName,
                Path = obj:GetFullName(),
                Instance = obj,
                Methods = {"FireServer"}
            })
        elseif obj:IsA("RemoteFunction") then
            table.insert(ScannedRemotes, {
                Type = "RemoteFunction",
                Name = obj.Name,
                Class = obj.ClassName,
                Path = obj:GetFullName(),
                Instance = obj,
                Methods = {"InvokeServer"}
            })
        end
    end
    
    return ScannedRemotes
end

-- Parse arguments
local function ParseArgs(argsString)
    if argsString == "{}" or argsString == "" then
        return {}
    end
    
    local success, result = pcall(function()
        return HttpService:JSONDecode(argsString)
    end)
    
    if success then
        return result
    else
        local args = {}
        for arg in string.gmatch(argsString, "([^,]+)") do
            local trimmed = arg:match("^%s*(.-)%s*$")
            
            if tonumber(trimmed) then
                table.insert(args, tonumber(trimmed))
            elseif trimmed == "true" then
                table.insert(args, true)
            elseif trimmed == "false" then
                table.insert(args, false)
            elseif trimmed == "nil" then
                table.insert(args, nil)
            else
                table.insert(args, trimmed:gsub('^"?(.-)"?$', '%1'))
            end
        end
        return args
    end
end

-- Spam remote
local function SpamRemote(remote, method, args, interval)
    if not remote then return end
    
    local argsTable = ParseArgs(args)
    local connectionName = tostring(remote) .. "_" .. method
    
    -- Stop existing spam
    if SpammedRemotes[connectionName] then
        SpammedRemotes[connectionName]:Disconnect()
        SpammedRemotes[connectionName] = nil
    end
    
    -- Start new spam
    local connection = RunService.Heartbeat:Connect(function()
        if not Config.RemoteSpam then
            connection:Disconnect()
            SpammedRemotes[connectionName] = nil
            return
        end
        
        pcall(function()
            if method == "FireServer" and remote:IsA("RemoteEvent") then
                remote:FireServer(unpack(argsTable))
            elseif method == "InvokeServer" and remote:IsA("RemoteFunction") then
                remote:InvokeServer(unpack(argsTable))
            end
        end)
        
        wait(interval)
    end)
    
    SpammedRemotes[connectionName] = connection
    
    WindUI:Notify({
        Title = "Spam Started",
        Content = string.format("Spamming %s every %.2fs", remote.Name, interval)
    })
end

-- Stop all spam
local function StopAllSpam()
    Config.RemoteSpam = false
    for name, conn in pairs(SpammedRemotes) do
        if conn then
            conn:Disconnect()
        end
    end
    SpammedRemotes = {}
    WindUI:Notify({Title = "Spam Stopped", Content = "All remote spam disabled"})
end

