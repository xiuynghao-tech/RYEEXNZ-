--    GLOBAL KEYBINDS
-- ════════════════════════════════════════
local _speedLabel = nil  -- diisi setelah UI dibuat

-- [F3] Toggle FreeCam | [=] Speed+5 | [-] Speed-5
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end

    if input.KeyCode == Enum.KeyCode.F3 then
        if FreeCamState.Enabled then DisableFreeCam() else EnableFreeCam() end
    end

    if input.KeyCode == Enum.KeyCode.Equals then
        FreeCamState.Speed = math.clamp(FreeCamState.Speed + 5, 1, 200)
        if _speedLabel then
            _speedLabel:SetText("Speed: " .. FreeCamState.Speed .. "  |  [+] tambah  [-] kurangi")
        end
    end

    if input.KeyCode == Enum.KeyCode.Minus then
        FreeCamState.Speed = math.clamp(FreeCamState.Speed - 5, 1, 200)
        if _speedLabel then
            _speedLabel:SetText("Speed: " .. FreeCamState.Speed .. "  |  [+] tambah  [-] kurangi")
        end
    end
end)

-- [Scroll] Zoom In / Out (hanya saat FreeCam aktif)
UserInputService.InputChanged:Connect(function(input)
    if not FreeCamState.Enabled then return end
    if input.UserInputType == Enum.UserInputType.MouseWheel then
        local delta = input.Position.Z
        FreeCamState._targetFOV = math.clamp(
            FreeCamState._targetFOV - delta * FreeCamState.ZoomSpeed,
            5, 120
        )
    end
end)

-- ════════════════════════════════════════
--           GRAPHIC FUNCTIONS
-- ════════════════════════════════════════
local function SetDepthOfField(enabled)
    local old = Lighting:FindFirstChildOfClass("DepthOfFieldEffect")
    if old then old:Destroy() end
    GraphicState._dofEffect  = nil
    GraphicState.DepthOfField = enabled
    if enabled then
        local dof = Instance.new("DepthOfFieldEffect")
        dof.FocusDistance = GraphicState._dofFocus
        dof.InFocusRadius = GraphicState._dofFocusRange
        dof.NearIntensity  = GraphicState._dofAperture
        dof.FarIntensity   = GraphicState._dofAperture
        dof.Parent = Lighting
        GraphicState._dofEffect = dof
    end
end

local function SetGlossyTexture(enabled)
    GraphicState.GlossyTexture = enabled
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and enabled and obj.Material == Enum.Material.Plastic then
            obj.Material = Enum.Material.SmoothPlastic
        end
    end
end

local function SetHighTexture(enabled)
    GraphicState.HighTexture = enabled
    if enabled then
        settings().Rendering.QualityLevel = 21
        Lighting.Technology = Enum.Technology.Future
        Lighting.GlobalShadows = true
        Lighting.ShadowSoftness = 0.2
        Lighting.EnvironmentDiffuseScale  = 1
        Lighting.EnvironmentSpecularScale = 1
    else
        settings().Rendering.QualityLevel = 10
        Lighting.Technology = Enum.Technology.ShadowMap
    end
end

local function SetLockRender(enabled)
    GraphicState.LockRender = enabled
    settings().Rendering.QualityLevel = enabled and 10 or 10
end

