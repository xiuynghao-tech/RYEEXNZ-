local function GetNonAnchoredParts(radius)
    local parts = {}
    SafeCall(function()
        local character = LocalPlayer.Character
        if not character then return end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        local position = rootPart.Position
        
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj.Anchored and obj.Parent and not obj.Parent:IsA("Accoutrement") then
                local dist = (obj.Position - position).magnitude
                if dist <= radius then
                    table.insert(parts, obj)
                end
            end
        end
    end)
    return parts
end

local function BringAllParts()
    if not Config.BringPart then return end
    
    SafeCall(function()
        local character = LocalPlayer.Character
        if not character then return end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        local parts = GetNonAnchoredParts(Config.PartRadius)
        local count = 0
        
        for _, part in ipairs(parts) do
            part.CFrame = rootPart.CFrame * CFrame.new(0, 2, count * 2)
            part.Velocity = Vector3.new(0, 0, 0)
            part.RotVelocity = Vector3.new(0, 0, 0)
            count = count + 1
        end
    end)
end

local function FlyPartsToRandom()
    if not Config.FlyingPart then return end
    
    SafeCall(function()
        local players = Players:GetPlayers()
        if #players < 2 then return end
        
        local targetPlayer = players[math.random(1, #players)]
        while targetPlayer == LocalPlayer and #players > 1 do
            targetPlayer = players[math.random(1, #players)]
        end
        
        if not targetPlayer or not targetPlayer.Character then return end
        
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot then return end
        
        local parts = GetNonAnchoredParts(Config.PartRadius)
        local count = 0
        
        for _, part in ipairs(parts) do
            part.CFrame = targetRoot.CFrame * CFrame.new(0, 5, count * 2)
            part.Velocity = (targetRoot.Position - part.Position).unit * 200
            part.RotVelocity = Vector3.new(math.random(-50, 50), math.random(-50, 50), math.random(-50, 50))
            count = count + 1
        end
    end)
end

