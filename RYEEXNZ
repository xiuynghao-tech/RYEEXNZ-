-- Keyboard input
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not State.Enabled then return end
    
    -- Movement keys
    if input.KeyCode == Enum.KeyCode.W then
        State.MoveKeys.Forward = true
    elseif input.KeyCode == Enum.KeyCode.S then
        State.MoveKeys.Backward = true
    elseif input.KeyCode == Enum.KeyCode.A then
        State.MoveKeys.Left = true
    elseif input.KeyCode == Enum.KeyCode.D then
        State.MoveKeys.Right = true
    elseif input.KeyCode == Enum.KeyCode.Q then
        State.MoveKeys.Down = true
    elseif input.KeyCode == Enum.KeyCode.E then
        State.MoveKeys.Up = true
    end
    
    -- Keybinds
    if input.KeyCode == State.Keybinds.Toggle then
        toggleFreecam()
    elseif input.KeyCode == State.Keybinds.Reset then
        resetCamera()
    elseif input.KeyCode == State.Keybinds.SpeedUp then
        State.Speed = math.min(State.Speed + 5, 100)
        WindUI:Notify({
            Title = "Speed: " .. State.Speed,
            Duration = 1
        })
    elseif input.KeyCode == State.Keybinds.SpeedDown then
        State.Speed = math.max(State.Speed - 5, 5)
        WindUI:Notify({
            Title = "Speed: " .. State.Speed,
            Duration = 1
        })
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Movement keys
    if input.KeyCode == Enum.KeyCode.W then
        State.MoveKeys.Forward = false
    elseif input.KeyCode == Enum.KeyCode.S then
        State.MoveKeys.Backward = false
    elseif input.KeyCode == Enum.KeyCode.A then
        State.MoveKeys.Left = false
    elseif input.KeyCode == Enum.KeyCode.D then
        State.MoveKeys.Right = false
    elseif input.KeyCode == Enum.KeyCode.Q then
        State.MoveKeys.Down = false
    elseif input.KeyCode == Enum.KeyCode.E then
        State.MoveKeys.Up = false
    end
end)

-- Mouse input untuk rotasi
UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not State.Enabled then return end
    
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            -- Hitung delta mouse
            local delta = input.Delta
            State.TargetRotation = Vector2.new(
                State.TargetRotation.X - delta.X * State.MouseSensitivity,
                math.clamp(State.TargetRotation.Y - delta.Y * State.MouseSensitivity, -1.4, 1.4)
            )
        end
    end
end)

-- Mouse button untuk lock/unlock rotasi
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not State.Enabled then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    end
end)

-- Mouse wheel untuk FOV
UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not State.Enabled then return end
    
    if input.UserInputType == Enum.UserInputType.MouseWheel then
        State.FOV = math.clamp(State.FOV - input.Position.Z * 5, 20, 120)
        Camera.FieldOfView = State.FOV
        
        -- Update UI
        if _G.FOVSlider then
            _G.FOVSlider:SetValue(State.FOV)
        end
    end
end)

-- =====================================================
-- SMOOTH CAMERA LOOP
-- =====================================================
RunService.RenderStepped:Connect(function(deltaTime)
    if not State.Enabled then return end
    
    -- Hitung movement vector
    local moveDir = Vector3.new(0, 0, 0)
    if State.MoveKeys.Forward then moveDir = moveDir + Vector3.new(0, 0, -1) end
    if State.MoveKeys.Backward then moveDir = moveDir + Vector3.new(0, 0, 1) end
    if State.MoveKeys.Left then moveDir = moveDir + Vector3.new(-1, 0, 0) end
    if State.MoveKeys.Right then moveDir = moveDir + Vector3.new(1, 0, 0) end
    if State.MoveKeys.Up then moveDir = moveDir + Vector3.new(0, 1, 0) end
    if State.MoveKeys.Down then moveDir = moveDir + Vector3.new(0, -1, 0) end
    
    if moveDir.Magnitude > 0 then
        moveDir = moveDir.Unit
        
        -- Rotasi movement berdasarkan rotasi kamera
        local cameraCF = CFrame.Angles(0, State.TargetRotation.X, 0)
        moveDir = cameraCF:VectorToWorldSpace(moveDir)
        
        -- Update target position
        State.TargetPosition = State.TargetPosition + moveDir * State.Speed * deltaTime
    end
    
    -- Smooth interpolation
    State.CameraPosition = State.CameraPosition:Lerp(State.TargetPosition, State.Smoothness)
    State.CameraRotation = State.CameraRotation:Lerp(State.TargetRotation, State.Smoothness * 2)
    
    -- Update camera
    local cameraCF = CFrame.new(State.CameraPosition) * CFrame.Angles(State.CameraRotation.Y, State.CameraRotation.X, 0)
    Camera.CFrame = cameraCF
    
    -- Path recording
    if State.IsRecording then
        table.insert(State.RecordedPath, {
            Position = State.CameraPosition,
            Rotation = State.CameraRotation,
            FOV = State.FOV,
            Time = tick()
        })
    end
    
    -- Path playback
    if State.IsPlayingPath and State.RecordedPath and #State.RecordedPath > 0 then
        local currentData = State.RecordedPath[State.CurrentPathIndex]
        if currentData then
            State.TargetPosition = currentData.Position
            State.TargetRotation = currentData.Rotation
            State.FOV = currentData.FOV
            Camera.FieldOfView = State.FOV
            
            State.CurrentPathIndex = State.CurrentPathIndex + 1
            if State.CurrentPathIndex > #State.RecordedPath then
                State.CurrentPathIndex = 1
            end
        end
    end
    
    -- Update grid position
    if State.ShowGrid then
        for _, part in ipairs(State.GridParts) do
            if part then
                part.Position = Vector3.new(
                    math.floor((State.CameraPosition.X + 25) / 5) * 5 - 25,
                    0,
                    math.floor((State.CameraPosition.Z + 25) / 5) * 5 - 25
                )
            end
        end
    end
    
    -- Update coordinate display
    if State.ShowCoordinates and _G.CoordLabel then
        _G.CoordLabel:SetText(string.format("X: %.1f  Y: %.1f  Z: %.1f", 
            State.CameraPosition.X, 
            State.CameraPosition.Y, 
            State.CameraPosition.Z
        ))
    end
end)

