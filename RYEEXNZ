        if not myRoot then return end
        
        local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
        
        for i, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    if not Config.ESPTracers[i] then
                        Config.ESPTracers[i] = Drawing.new("Line")
                        Config.ESPTracers[i].Thickness = 2
                        Config.ESPTracers[i].Transparency = 0.7
                    end
                    
                    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        Config.ESPTracers[i].From = screenCenter
                        Config.ESPTracers[i].To = Vector2.new(screenPos.X, screenPos.Y)
                        Config.ESPTracers[i].Color = Config.ESPColor
                        Config.ESPTracers[i].Visible = true
                    else
                        Config.ESPTracers[i].Visible = false
                    end
                end
            end
        end
    end)
end

local function ToggleESP(state)
    Config.ESP = state
    
