-- Simpan posisi asli avatar
local originalCFrame = nil

-- Fungsi untuk mengunci avatar di tempat
local function lockAvatar()
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            -- Simpan posisi asli
            originalCFrame = rootPart.CFrame
            
            -- Kunci avatar
            humanoid.PlatformStand = true
            rootPart.Anchored = true
            rootPart.Velocity = Vector3.new(0, 0, 0)
            rootPart.RotVelocity = Vector3.new(0, 0, 0)
        end
    end
end

-- Fungsi untuk membuka kunci avatar
local function unlockAvatar()
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            humanoid.PlatformStand = false
            rootPart.Anchored = false
        end
    end
end

-- Toggle freecam
local function toggleFreecam()
    State.Freecam.Enabled = not State.Freecam.Enabled
    
    if State.Freecam.Enabled then
        -- Simpan posisi kamera awal
        State.Freecam.CameraPosition = Camera.CFrame.Position
        State.Freecam.TargetPosition = State.Freecam.CameraPosition
        
        -- Simpan rotasi awal
        local _, lookY = Camera.CFrame:ToOrientation()
        State.Freecam.CameraRotation = Vector2.new(math.deg(lookY), 0)
        State.Freecam.TargetRotation = State.Freecam.CameraRotation
        
        -- Set camera type
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.FieldOfView = State.Freecam.FOV
        
        -- Kunci avatar di tempat
        lockAvatar()
        
        -- Mouse settings
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        UserInputService.MouseIconEnabled = false
        
        WindUI:Notify({
            Title = "✅ Freecam Enabled",
            Content = "Avatar diam di tempat | Speed: " .. State.Freecam.Speed,
            Duration = 3
        })
    else
        -- Kembalikan camera
        Camera.CameraType = Enum.CameraType.Custom
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
        
        -- Buka kunci avatar
        unlockAvatar()
        
        WindUI:Notify({
            Title = "⏹ Freecam Disabled",
            Content = "Kamera kembali ke player",
            Duration = 2
        })
    end
end

-- Reset kamera
local function resetCamera()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local rootPart = LocalPlayer.Character.HumanoidRootPart
        State.Freecam.TargetPosition = rootPart.Position + Vector3.new(0, 2, 5)
        State.Freecam.TargetRotation = Vector2.new(0, 0)
        
        WindUI:Notify({
            Title = "🔄 Camera Reset",
            Content = "Kamera kembali ke player",
            Duration = 2
        })
    end
end

-- Input handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if State.Freecam.Enabled then
        -- Movement keys
        if input.KeyCode == Enum.KeyCode.W then
            State.Freecam.MoveKeys.Forward = true
        elseif input.KeyCode == Enum.KeyCode.S then
            State.Freecam.MoveKeys.Backward = true
        elseif input.KeyCode == Enum.KeyCode.A then
            State.Freecam.MoveKeys.Left = true
        elseif input.KeyCode == Enum.KeyCode.D then
            State.Freecam.MoveKeys.Right = true
        elseif input.KeyCode == Enum.KeyCode.Q then
            State.Freecam.MoveKeys.Down = true
        elseif input.KeyCode == Enum.KeyCode.E then
            State.Freecam.MoveKeys.Up = true
        end
    end
    
    -- Keybinds (always active)
    if input.KeyCode == State.Freecam.Keybinds.Toggle then
        toggleFreecam()
    elseif input.KeyCode == State.Freecam.Keybinds.Reset then
        resetCamera()
    elseif input.KeyCode == State.Freecam.Keybinds.SpeedUp then
        State.Freecam.Speed = math.min(State.Freecam.Speed + 5, 100)
        if _G.SpeedSlider then _G.SpeedSlider:SetValue(State.Freecam.Speed) end
    elseif input.KeyCode == State.Freecam.Keybinds.SpeedDown then
        State.Freecam.Speed = math.max(State.Freecam.Speed - 5, 5)
        if _G.SpeedSlider then _G.SpeedSlider:SetValue(State.Freecam.Speed) end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if State.Freecam.Enabled then
        if input.KeyCode == Enum.KeyCode.W then
            State.Freecam.MoveKeys.Forward = false
        elseif input.KeyCode == Enum.KeyCode.S then
            State.Freecam.MoveKeys.Backward = false
        elseif input.KeyCode == Enum.KeyCode.A then
            State.Freecam.MoveKeys.Left = false
        elseif input.KeyCode == Enum.KeyCode.D then
            State.Freecam.MoveKeys.Right = false
        elseif input.KeyCode == Enum.KeyCode.Q then
            State.Freecam.MoveKeys.Down = false
        elseif input.KeyCode == Enum.KeyCode.E then
            State.Freecam.MoveKeys.Up = false
        end
    end
end)

-- Mouse rotation
UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not State.Freecam.Enabled then return end
    
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local delta = input.Delta
            State.Freecam.TargetRotation = Vector2.new(
                State.Freecam.TargetRotation.X - delta.X * State.Freecam.MouseSensitivity,
                math.clamp(State.Freecam.TargetRotation.Y - delta.Y * State.Freecam.MouseSensitivity, -1.4, 1.4)
            )
        end
    end
end)

-- Smooth camera loop
RunService.RenderStepped:Connect(function(deltaTime)
    if not State.Freecam.Enabled then return end
    
    -- Hitung movement vector
    local moveDir = Vector3.new(0, 0, 0)
    if State.Freecam.MoveKeys.Forward then moveDir = moveDir + Vector3.new(0, 0, -1) end
    if State.Freecam.MoveKeys.Backward then moveDir = moveDir + Vector3.new(0, 0, 1) end
    if State.Freecam.MoveKeys.Left then moveDir = moveDir + Vector3.new(-1, 0, 0) end
    if State.Freecam.MoveKeys.Right then moveDir = moveDir + Vector3.new(1, 0, 0) end
    if State.Freecam.MoveKeys.Up then moveDir = moveDir + Vector3.new(0, 1, 0) end
    if State.Freecam.MoveKeys.Down then moveDir = moveDir + Vector3.new(0, -1, 0) end
    
    if moveDir.Magnitude > 0 then
        moveDir = moveDir.Unit
        local cameraCF = CFrame.Angles(0, State.Freecam.TargetRotation.X, 0)
        moveDir = cameraCF:VectorToWorldSpace(moveDir)
        State.Freecam.TargetPosition = State.Freecam.TargetPosition + moveDir * State.Freecam.Speed * deltaTime
    end
    
    -- Smooth interpolation
    State.Freecam.CameraPosition = State.Freecam.CameraPosition:Lerp(State.Freecam.TargetPosition, State.Freecam.Smoothness)
    State.Freecam.CameraRotation = State.Freecam.CameraRotation:Lerp(State.Freecam.TargetRotation, State.Freecam.Smoothness * 2)
    
    -- Update camera
    local cameraCF = CFrame.new(State.Freecam.CameraPosition) * CFrame.Angles(State.Freecam.CameraRotation.Y, State.Freecam.CameraRotation.X, 0)
    Camera.CFrame = cameraCF
end)

-- =====================================================
-- DEPTH OF FIELD SYSTEM
-- =====================================================

local function updateDOF()
    -- Hapus DOF lama
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("DepthOfFieldEffect") and v.Name == "RYEENZY_DOF" then
            v:Destroy()
        end
    end
    
    if not State.DOF.Enabled then return end
    
    local dof = Instance.new("DepthOfFieldEffect")
    dof.Name = "RYEENZY_DOF"
    dof.Enabled = true
    dof.FocusDistance = State.DOF.FocusDistance
    dof.InFocusRadius = State.DOF.InFocusRadius
    dof.NearIntensity = State.DOF.Intensity
    dof.FarIntensity = State.DOF.Intensity
    dof.Parent = Lighting
end

-- =====================================================
-- HIGH TEXTURE SYSTEM
-- =====================================================

local function updateHighTexture()
    -- Hapus efek lama
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("ColorCorrectionEffect") and v.Name == "RYEENZY_SHARPEN" then
            v:Destroy()
        end
        if v:IsA("BloomEffect") and v.Name == "RYEENZY_AA" then
            v:Destroy()
        end
    end
    
    if not State.HighTexture.Enabled then return end
    
    -- Sharpening effect
    local sharpen = Instance.new("ColorCorrectionEffect")
    sharpen.Name = "RYEENZY_SHARPEN"
    sharpen.Enabled = true
    sharpen.Contrast = 0.1 + State.HighTexture.SharpenAmount * 0.2
    sharpen.Saturation = 0.05
    sharpen.Parent = Lighting
    
    -- Anti-aliasing effect
    local aa = Instance.new("BloomEffect")
    aa.Name = "RYEENZY_AA"
    aa.Enabled = true
    aa.Intensity = 0.1
    aa.Size = 24
    aa.Threshold = 0.9
    aa.Parent = Lighting
end

-- =====================================================
-- ULTRA GLOSSY SYSTEM
-- =====================================================

local function updateUltraGlossy()
    -- Hapus efek lama
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("BloomEffect") and v.Name == "RYEENZY_GLOSS" then
            v:Destroy()
        end
        if v:IsA("ColorCorrectionEffect") and v.Name == "RYEENZY_GLOSS_COLOR" then
            v:Destroy()
        end
    end
    
    if not State.UltraGlossy.Enabled then return end
    
    -- Bloom untuk efek glossy
    local bloom = Instance.new("BloomEffect")
    bloom.Name = "RYEENZY_GLOSS"
    bloom.Enabled = true
    bloom.Intensity = State.UltraGlossy.BloomIntensity + 0.3
    bloom.Size = 32
    bloom.Threshold = 0.6
    bloom.Parent = Lighting
    
    -- Color correction untuk meningkatkan visual
    local color = Instance.new("ColorCorrectionEffect")
    color.Name = "RYEENZY_GLOSS_COLOR"
    color.Enabled = true
    color.Contrast = 0.15
    color.Saturation = 0.2
    color.Parent = Lighting
    
    -- Setting lingkungan
    Lighting.GlobalShadows = true
    Lighting.ShadowSoftness = 0.2
    
    -- Efek refleksi pada part
    task.spawn(function()
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and (v.Material == Enum.Material.Plastic or v.Material == Enum.Material.SmoothPlastic) then
                v.Reflectance = State.UltraGlossy.Intensity * 0.3
            elseif v:IsA("BasePart") and v.Material == Enum.Material.Metal then
                v.Reflectance = State.UltraGlossy.Intensity * 0.5
            end
        end
    end)
end

