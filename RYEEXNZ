        for _, obj in pairs(Config.ESPObjects) do
            pcall(function() obj:Destroy() end)
        end
        Config.ESPObjects = {}
        
        if state then
            for _, player in pairs(Players:GetPlayers()) do
                CreateESP(player)
            end
            
            Players.PlayerAdded:Connect(function(player)
                player.CharacterAdded:Connect(function()
                    wait(0.5)
                    if Config.ESP then
                        CreateESP(player)
                    end
                end)
            end)
        end
    end)
end

