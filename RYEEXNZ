-- Dapatkan semua part yang tidak di-anchor
local function GetUnanchoredParts(radius)
    local character = LocalPlayer.Character
    if not character then return {} end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return {} end
    
    local position = rootPart.Position
    local parts = {}
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj.Anchored and obj.Parent and not obj.Parent:IsA("Player") then
            local dist = (obj.Position - position).magnitude
            if dist <= radius then
                table.insert(parts, obj)
            end
        end
    end
    
    return parts
end

-- BRING PART - Tarik semua part ke player
local function BringPartsToPlayer()
    if not Config.BringPart then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local parts = GetUnanchoredParts(Config.PartRadius)
    local count = 0
    
    for _, part in ipairs(parts) do
        -- Pindahkan part ke depan player
        part.CFrame = rootPart.CFrame * CFrame.new(0, 2, count * 3)
        part.Velocity = Vector3.new(0, 0, 0)
        part.RotVelocity = Vector3.new(0, 0, 0)
        count = count + 1
    end
    
    if count > 0 then
        print("[BRING] Brought " .. count .. " parts to player")
    end
end

-- FLYING PART - Terbangkan part ke player random
local function FlyPartsToRandom()
    if not Config.FlyingPart then return end
    
    local parts = GetUnanchoredParts(Config.PartRadius)
    
    for _, part in ipairs(parts) do
        -- Cari player random (selain diri sendiri)
        local targetPlayer = nil
        local players = {}
        
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                table.insert(players, player)
            end
        end
        
        if #players > 0 then
            targetPlayer = players[math.random(#players)]
            
            if targetPlayer and targetPlayer.Character then
                local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    -- Hitung arah ke target
                    local direction = (targetRoot.Position - part.Position).unit
                    part.Velocity = direction * Config.PartSpeed
                end
            end
        end
    end
end

