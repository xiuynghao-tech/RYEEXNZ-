-- ════════════════════════════════════════
--   AUTO SCALE  (menyesuaikan resolusi layar)
-- ════════════════════════════════════════
local _userScale = nil  -- nil = auto, angka = manual override

local function ApplyAutoScale()
    if _userScale then
        -- Mode manual: pakai scale yang diset user
        Window:SetScale(_userScale)
        return
    end
    -- Mode auto: hitung dari viewport
    local vp     = Workspace.CurrentCamera.ViewportSize
    local scaleX = vp.X / 1920
    local scaleY = vp.Y / 1080
    local scale  = math.clamp(math.min(scaleX, scaleY), 0.4, 1.4)
    Window:SetScale(scale)
end

-- Terapkan saat pertama kali
